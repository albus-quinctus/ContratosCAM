# Dependencias de Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Datos crudos (pueden ser muy grandes para el repositorio)
data/raw/*.csv
data/raw/*.xml
data/raw/*.json
data/raw/*.xlsx

# Base de datos SQLite (puede ser muy grande para git)
data/db/*.db
data/db/*.db-shm
data/db/*.db-wal

# Mantener la estructura de directorios vacíos
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/db/.gitkeep

# Variables de entorno
.env
.env.local
.env.*.local

# Editores
.vscode/settings.json
.idea/
*.swp
*.swo
*~

# Sistema operativo
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Logs
logs/
*.log

# Archivos temporales
tmp/
temp/
*.tmp
