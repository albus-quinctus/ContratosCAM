# ═══════════════════════════════════════════════════════════════════════════════
# ContratosCAM — .gitignore
# ═══════════════════════════════════════════════════════════════════════════════

# ── Dependencias ─────────────────────────────────────────────────────────────
node_modules/

# ── Datos crudos (pueden ser muy grandes para el repositorio) ────────────────
data/raw/*.csv
data/raw/*.xml
data/raw/*.json
data/raw/*.xlsx
data/raw/*.atom

# ── Base de datos SQLite (se genera localmente) ──────────────────────────────
data/db/*.db
data/db/*.db-shm
data/db/*.db-wal

# ── Los JSON procesados SÍ se suben (los consume el frontend en GitHub Pages)
# data/processed/*.json  ← NO excluir

# ── Mantener estructura de directorios vacíos ────────────────────────────────
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/db/.gitkeep

# ── Variables de entorno ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── Editores e IDEs ──────────────────────────────────────────────────────────
.vscode/settings.json
.vscode/launch.json
.idea/
*.swp
*.swo
*~

# ── Sistema operativo ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*

# ── Temporales ───────────────────────────────────────────────────────────────
tmp/
temp/
*.tmp
_site/
